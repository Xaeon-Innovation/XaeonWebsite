{
  "compilerOptions": {
    "target": "es2020", // Modern JS output
    "module": "commonjs", // Node uses CommonJS
    "outDir": "./dist", // Compiled JS files
    "rootDir": "./src", // Source TS files
    "strict": true, // Enable strict type-checking
    "esModuleInterop": true, // For import compatibility
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
