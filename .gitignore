Documents

# Cursor IDE — local rules (machine/user specific)
.cursor/rules/

# Dependencies (npm packages)
node_modules/

# Raw design/asset library (keep out of git)
/images/
images/

# Curated public assets only (avoid committing huge asset dumps)
frontend/public/assets/
frontend/public/assets/**

# Backgrounds (prefer WebP in repo)
!frontend/public/assets/backgrounds/
!frontend/public/assets/backgrounds/**

# Case study images (prefer WebP in repo)
!frontend/public/assets/case-studies/
!frontend/public/assets/case-studies/**

# Hero / intro videos: commit only after compressing (WebM + small MP4; avoid huge masters)
!frontend/public/assets/videos/
!frontend/public/assets/videos/**

!frontend/public/assets/intro/
!frontend/public/assets/intro/**

# Environment files (never commit secrets)
.env
.env.*
backend/.env
frontend/.env